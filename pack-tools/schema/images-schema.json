{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://livingpatch.local/schema/images.schema.json",
  "title": "LivingPatch Images Pack Schema",
  "description": "Schema for image data packs containing Wikipedia images and metadata for species",
  "type": "object",
  "required": ["metadata", "data"],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Image pack metadata",
      "required": ["id", "createdDate", "status", "packId"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the images pack",
          "pattern": "^[a-z0-9_-]+$",
          "minLength": 1
        },
        "createdDate": {
          "type": "string",
          "description": "ISO 8601 date when images were fetched",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Images pack status: draft (incomplete) or published (complete)",
          "enum": ["draft", "published"],
          "default": "draft"
        },
        "packId": {
          "type": "string",
          "description": "ID of the source data pack these images are for",
          "pattern": "^[a-z0-9_-]+$",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this image collection"
        }
      }
    },
    "data": {
      "type": "array",
      "description": "Array of species image entries",
      "items": {
        "type": "object",
        "required": ["speciesId", "url", "author"],
        "properties": {
          "speciesId": {
            "type": "string",
            "description": "ID of the species this image is for"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the image on Wikimedia Commons"
          },
          "author": {
            "type": "string",
            "description": "Author/creator of the image"
          }
        }
      }
    }
  }
}
