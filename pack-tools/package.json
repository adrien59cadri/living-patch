{
  "name": "pack-tools",
  "version": "1.0.0",
  "description": "CLI tools for LivingPatch data pack validation, merging, and management",
  "type": "module",
  "main": "lib/index.ts",
  "scripts": {
    "validate": "node --loader ts-node/esm cli/validate.ts",
    "validate:watch": "node --loader ts-node/esm --watch cli/validate.ts",
    "merge": "node --loader ts-node/esm cli/merge.ts",
    "migrate": "node scripts/migrate-dataset.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint . --ext .ts"
  },
  "keywords": ["livingpatch", "data", "pack", "validation"],
  "author": "LivingPatch Contributors",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.22.4",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "vitest": "^1.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
