{
  "name": "livingpatch",
  "version": "0.1.0",
  "private": true,
  "description": "Ecological literacy tool for NE Pennsylvania species",
  "scripts": {
    "dev": "cd app && npm run dev",
    "build": "cd app && npm run build",
    "preview": "cd app && npm run preview",
    "lint": "cd app && npm run lint",
    "test": "cd app && npm run test",
    "test:run": "cd app && npm run test:run",
    "test:e2e": "cd app && npm run test:e2e",
    "ci:local": "act push --workflows .github/workflows/ci.yml --job ci",
    "e2e:local": "act push --workflows .github/workflows/ci.yml --job e2e"
  }
}
